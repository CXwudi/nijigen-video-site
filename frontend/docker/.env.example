# Copy this file to frontend/docker/.env before running frontend Docker commands.

COMPOSE_PROJECT_NAME=nijigen-video-site-frontend

FRONTEND_HTTP_PORT=5173
WEB_PNPM_IMAGE=nijigen-video-site-web-pnpm:local

JDK_VERSION=25

POSTGRES_DB=nijigen_video_site
POSTGRES_USER=nijigen
POSTGRES_PASSWORD=nijigen

API_APPLICATION_NAME=apps-api
API_HTTP_PORT=18080

# Required local user mapping for source-mounted Gradle and pnpm runs.
# Some mise tasks will override these two env vars with the correct current host user when possible.
# But these two env vars still need to be provided here to make other docker compose command satisfied
HOST_UID=1000
HOST_GID=1000
# HOST_GRADLE_USER_HOME=/home/you/.gradle
