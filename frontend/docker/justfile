set shell := ["bash", "-euo", "pipefail", "-c"]
set windows-shell := ["bash", "-euo", "pipefail", "-c"]

compose := "docker compose --env-file .env -f compose.local.yml"

# Start the frontend local stack: web, api, postgres, redis, and flyway.
up:
  #!/usr/bin/env bash
  set -euo pipefail
  export HOST_GRADLE_USER_HOME="${HOST_GRADLE_USER_HOME:-$HOME/.gradle}"
  export HOST_UID="${HOST_UID:-$(id -u)}"
  export HOST_GID="${HOST_GID:-$(id -g)}"
  mkdir -p "$HOST_GRADLE_USER_HOME"
  {{compose}} up -d

# Stop all frontend local Docker services managed by this file.
down:
  {{compose}} down --remove-orphans

# Print the fully resolved Compose config.
config:
  {{compose}} config

# Validate the resolved Compose config.
config-check:
  {{compose}} config --quiet

# Run one-off commands against a frontend stack service.
#
# Examples:
#   just docker run --rm api :apps:api:test
#   just docker run --rm --entrypoint /bin/sh web -c 'nginx -v'
[positional-arguments]
run +args:
  #!/usr/bin/env bash
  set -euo pipefail
  export HOST_GRADLE_USER_HOME="${HOST_GRADLE_USER_HOME:-$HOME/.gradle}"
  export HOST_UID="${HOST_UID:-$(id -u)}"
  export HOST_GID="${HOST_GID:-$(id -g)}"
  mkdir -p "$HOST_GRADLE_USER_HOME"
  {{compose}} run "$@"
