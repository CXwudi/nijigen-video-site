# Copy this file to backend/docker/.env before running backend Docker commands.

COMPOSE_PROJECT_NAME=nijigen-video-site-backend

JDK_VERSION=25

POSTGRES_VERSION=17
POSTGRES_DB=nijigen_video_site
POSTGRES_USER=nijigen
POSTGRES_PASSWORD=nijigen
POSTGRES_HOST_PORT=5432

REDIS_VERSION=8
REDIS_HOST_PORT=6379

FLYWAY_VERSION=11

API_APPLICATION_NAME=apps-api
API_HTTP_PORT=8080

# Optional local user mapping for source-mounted Gradle runs.
# The backend Docker Just recipes set these automatically when possible.
# HOST_UID=1000
# HOST_GID=1000
# HOST_GRADLE_USER_HOME=/home/you/.gradle
