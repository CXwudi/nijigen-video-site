set shell := ["bash", "-euo", "pipefail", "-c"]
set windows-shell := ["bash", "-euo", "pipefail", "-c"]

[arg('profile', help='Compose profile: dev-local, dev-container-jb, or prod', pattern='dev-local|dev-container-jb|prod')]
up profile='prod':
  #!/usr/bin/env bash
  set -euo pipefail
  compose_file=''
  profile_args=()
  up_args=(-d)
  case "{{profile}}" in
    dev-local)
      compose_file='compose.dev.yml'
      ;;
    dev-container-jb)
      compose_file='compose.dev.yml'
      profile_args=(--profile dev-container-jb)
      ;;
    prod)
      compose_file='compose.prod.yml'
      up_args=(--build -d)
      ;;
    *)
      echo "Unknown profile: {{profile}}" >&2
      echo "Available profiles: dev-local, dev-container-jb, prod" >&2
      exit 1
      ;;
  esac
  docker compose \
    --env-file .env \
    -f "$compose_file" \
    "${profile_args[@]}" \
    up "${up_args[@]}"

[arg('profile', help='Compose profile: dev-local, dev-container-jb, run, or prod', pattern='dev-local|dev-container-jb|run|prod')]
down profile='prod':
  #!/usr/bin/env bash
  set -euo pipefail
  compose_file=''
  profile_args=()
  case "{{profile}}" in
    dev-local)
      compose_file='compose.dev.yml'
      ;;
    dev-container-jb)
      compose_file='compose.dev.yml'
      profile_args=(--profile dev-container-jb)
      ;;
    run)
      compose_file='compose.run.yml'
      export HOST_GRADLE_USER_HOME="${HOST_GRADLE_USER_HOME:-$HOME/.gradle}"
      export HOST_UID="${HOST_UID:-$(id -u)}"
      export HOST_GID="${HOST_GID:-$(id -g)}"
      ;;
    prod)
      compose_file='compose.prod.yml'
      ;;
    *)
      echo "Unknown profile: {{profile}}" >&2
      echo "Available profiles: dev-local, dev-container-jb, run, prod" >&2
      exit 1
      ;;
  esac
  docker compose \
    --env-file .env \
    -f "$compose_file" \
    "${profile_args[@]}" \
    down --remove-orphans

[arg('profile', help='Compose config target: dev-local, dev-container-jb, run, or prod', pattern='dev-local|dev-container-jb|run|prod')]
check-config profile='prod':
  #!/usr/bin/env bash
  set -euo pipefail
  compose_file=''
  profile_args=()
  case "{{profile}}" in
    dev-local)
      compose_file='compose.dev.yml'
      ;;
    dev-container-jb)
      compose_file='compose.dev.yml'
      profile_args=(--profile dev-container-jb)
      ;;
    run)
      compose_file='compose.run.yml'
      export HOST_GRADLE_USER_HOME="${HOST_GRADLE_USER_HOME:-$HOME/.gradle}"
      export HOST_UID="${HOST_UID:-$(id -u)}"
      export HOST_GID="${HOST_GID:-$(id -g)}"
      ;;
    prod)
      compose_file='compose.prod.yml'
      ;;
    *)
      echo "Unknown profile: {{profile}}" >&2
      echo "Available profiles: dev-local, dev-container-jb, run, prod" >&2
      exit 1
      ;;
  esac
  docker compose \
    --env-file .env \
    -f "$compose_file" \
    "${profile_args[@]}" \
    config

# Run a service from compose.run.yml with raw `docker compose run` args, with some env vars set properly
[positional-arguments]
[arg('args', help='Raw `docker compose run` args, e.g. --rm api-gradle :apps:api:test')]
run +args:
  #!/usr/bin/env bash
  set -euo pipefail

  export HOST_GRADLE_USER_HOME="${HOST_GRADLE_USER_HOME:-$HOME/.gradle}"
  export HOST_UID="${HOST_UID:-$(id -u)}"
  export HOST_GID="${HOST_GID:-$(id -g)}"
  mkdir -p "$HOST_GRADLE_USER_HOME"

  docker compose \
    --env-file .env \
    -f compose.run.yml \
    run "$@"

check-backend-all:
  just run --rm api-gradle :apps:api:test :apps:api:nativeCompile :apps:api:nativeTest
