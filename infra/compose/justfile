set shell := ["bash", "-euo", "pipefail", "-c"]
set windows-shell := ["bash", "-euo", "pipefail", "-c"]

[arg('profile', help='Compose profile: dev-local, dev-container-jb, or prod', pattern='dev-local|dev-container-jb|prod')]
up profile='prod':
  #!/usr/bin/env bash
  set -euo pipefail
  compose_file=''
  profile_args=()
  up_args=(-d)
  case "{{profile}}" in
    dev-local)
      compose_file='compose.dev.yml'
      ;;
    dev-container-jb)
      compose_file='compose.dev.yml'
      profile_args=(--profile dev-container-jb)
      ;;
    prod)
      compose_file='compose.prod.yml'
      up_args=(--build -d)
      ;;
    *)
      echo "Unknown profile: {{profile}}" >&2
      echo "Available profiles: dev-local, dev-container-jb, prod" >&2
      exit 1
      ;;
  esac
  docker compose \
    --env-file .env \
    -f "$compose_file" \
    "${profile_args[@]}" \
    up "${up_args[@]}"

[arg('profile', help='Compose profile: dev-local, dev-container-jb, or prod', pattern='dev-local|dev-container-jb|prod')]
down profile='prod':
  #!/usr/bin/env bash
  set -euo pipefail
  compose_file=''
  profile_args=()
  case "{{profile}}" in
    dev-local)
      compose_file='compose.dev.yml'
      ;;
    dev-container-jb)
      compose_file='compose.dev.yml'
      profile_args=(--profile dev-container-jb)
      ;;
    prod)
      compose_file='compose.prod.yml'
      ;;
    *)
      echo "Unknown profile: {{profile}}" >&2
      echo "Available profiles: dev-local, dev-container-jb, prod" >&2
      exit 1
      ;;
  esac
  docker compose \
    --env-file .env \
    -f "$compose_file" \
    "${profile_args[@]}" \
    down --remove-orphans

[arg('profile', help='Compose config target: dev-local, dev-container-jb, ci, or prod', pattern='dev-local|dev-container-jb|ci|prod')]
check-config profile='prod':
  #!/usr/bin/env bash
  set -euo pipefail
  compose_file=''
  profile_args=()
  case "{{profile}}" in
    dev-local)
      compose_file='compose.dev.yml'
      ;;
    dev-container-jb)
      compose_file='compose.dev.yml'
      profile_args=(--profile dev-container-jb)
      ;;
    ci)
      compose_file='compose.ci.yml'
      export HOST_GRADLE_USER_HOME="${HOST_GRADLE_USER_HOME:-$HOME/.gradle}"
      export HOST_UID="${HOST_UID:-$(id -u)}"
      export HOST_GID="${HOST_GID:-$(id -g)}"
      ;;
    prod)
      compose_file='compose.prod.yml'
      ;;
    *)
      echo "Unknown profile: {{profile}}" >&2
      echo "Available profiles: dev-local, dev-container-jb, ci, prod" >&2
      exit 1
      ;;
  esac
  docker compose \
    --env-file .env \
    -f "$compose_file" \
    "${profile_args[@]}" \
    config

verify-jvm:
  #!/usr/bin/env bash
  set -euo pipefail
  export HOST_GRADLE_USER_HOME="${HOST_GRADLE_USER_HOME:-$HOME/.gradle}"
  export HOST_UID="${HOST_UID:-$(id -u)}"
  export HOST_GID="${HOST_GID:-$(id -g)}"
  mkdir -p "$HOST_GRADLE_USER_HOME"
  docker compose \
    --env-file .env \
    -f compose.ci.yml \
    run --rm backend-jvm-verification

[arg('task', help='Native verification task set: all, compile, or test', pattern='all|compile|test')]
verify-native task='all':
  #!/usr/bin/env bash
  set -euo pipefail
  export HOST_GRADLE_USER_HOME="${HOST_GRADLE_USER_HOME:-$HOME/.gradle}"
  export HOST_UID="${HOST_UID:-$(id -u)}"
  export HOST_GID="${HOST_GID:-$(id -g)}"
  mkdir -p "$HOST_GRADLE_USER_HOME"
  tasks=()
  case "{{task}}" in
    all)
      tasks=('nativeCompile' 'nativeTest')
      ;;
    test)
      tasks=('nativeTest')
      ;;
    compile)
      tasks=('nativeCompile')
      ;;
    *)
      echo "Unknown native verification task: {{task}}" >&2
      echo "Available native verification tasks: all, compile, test" >&2
      exit 1
      ;;
  esac
  docker compose \
    --env-file .env \
    -f compose.ci.yml \
    run --rm backend-native-verification "${tasks[@]}"

verify-all:
  just verify-jvm
  just verify-native all
