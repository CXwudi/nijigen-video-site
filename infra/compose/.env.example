# Copy this file to infra/compose/.env for local/manual Compose experiments.
# Production deployment uses prod.env copied from prod.env.example.

COMPOSE_PROJECT_NAME=nijigen-video-site

JDK_VERSION=25
API_PROD_RUNTIME_TARGET=api-native-runtime

POSTGRES_VERSION=17
POSTGRES_DB=nijigen_video_site
POSTGRES_USER=nijigen
POSTGRES_PASSWORD=nijigen
POSTGRES_HOST_PORT=5432

REDIS_VERSION=8
REDIS_HOST_PORT=6379

FLYWAY_VERSION=11

API_APPLICATION_NAME=apps-api
API_HTTP_PORT=8080
